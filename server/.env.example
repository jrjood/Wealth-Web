# Server Configuration
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Database Configuration (MySQL)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# For cPanel/phpMyAdmin, get these details from your hosting panel
DATABASE_URL="mysql://username:password@localhost:3306/wealth_holding"

# JWT Secret (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Job application notifications
HR_EMAIL=hr@wealthholding-eg.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=wealthholding@wealthholding-eg.com

# Admin Default Credentials (for first-time setup)
ADMIN_EMAIL=admin@wealthholding.com
ADMIN_PASSWORD=changeme123
